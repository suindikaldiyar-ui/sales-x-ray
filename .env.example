# ──────────────────────────────────────────────────────────────────────────
# Sales X-Ray — environment variables
# Copy this file to `.env.local` and fill in the values from your Supabase
# project. NEVER commit `.env.local`.
#
# Where to find these:
#   Supabase Dashboard → your project → Project Settings → API
#   Supabase Dashboard → your project → Project Settings → Database (for DATABASE_URL)
# ──────────────────────────────────────────────────────────────────────────

# Public — safe to expose to the browser (used by the client SDK).
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# Project Settings → API → Project API keys → `anon` `public`
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — NEVER expose to the browser. Bypasses Row Level Security,
# so it is only imported in server code (lib/supabase/admin.ts is server-only).
# Project Settings → API → Project API keys → `service_role` `secret`
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Server-only — direct Postgres connection string, used ONLY to apply the SQL
# migrations in supabase/migrations (e.g. via `psql` or the Supabase CLI).
# The running app talks to Supabase over the SDK, not this URL.
# Project Settings → Database → Connection string → URI (use the pooler in prod).
DATABASE_URL=postgresql://postgres:[YOUR-DB-PASSWORD]@db.YOUR-PROJECT-ref.supabase.co:5432/postgres

# Public — the canonical site URL, used to build email-confirmation and
# invitation redirect links. In production set this to your real domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only — default amoCRM sync window in days (how far back a normal sync
# pulls). Keep small for large accounts; "Полная история" always uses 365.
SYNC_WINDOW_DAYS=30
